# SMTP usado pelo backend para enviar os e-mails.
# No Vercel, cadastre estas variáveis em Project Settings > Environment Variables.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=laboratorio@datarestore.com.br
SMTP_PASS=sua_senha_do_email
EMAIL_FROM=laboratorio@datarestore.com.br

# Quem recebe os formulários. Para mais de um e-mail, separe por vírgula.
EMAIL_TO=laboratorio@datarestore.com.br

# O contato preenchido no formulário será adicionado ao final deste assunto.
EMAIL_SUBJECT=Novo formulário recebido
