# SMTP usado pelo backend para enviar os e-mails.
# No Vercel, cadastre estas variáveis em Project Settings > Environment Variables.
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@seudominio.com
SMTP_PASS=sua_senha_ou_app_password
EMAIL_FROM="Formulário <usuario@seudominio.com>"

# Opcional: um assunto padrão para o e-mail.
EMAIL_SUBJECT="Novo formulário recebido"
